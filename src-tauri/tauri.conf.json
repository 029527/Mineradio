{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mineradio",
  "version": "1.1.1",
  "identifier": "com.mineradio.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "beforeDevCommand": "cd frontend && bun run build",
    "beforeBuildCommand": "cd frontend && bun run build"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Music",
    "copyright": "© 2026 Mineradio",
    "shortDescription": "沉浸式音乐播放器",
    "longDescription": "Mineradio 沉浸式音乐播放器：天气电台、搜索播放、歌词舞台、粒子视觉与播客 DJ 节拍。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "windowSize": {
          "width": 620,
          "height": 400
        },
        "appPosition": {
          "x": 165,
          "y": 185
        },
        "applicationFolderPosition": {
          "x": 455,
          "y": 185
        }
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}