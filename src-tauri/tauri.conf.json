{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mineradio",
  "version": "1.1.1",
  "identifier": "com.mineradio.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "beforeDevCommand": "cd frontend && bun run build",
    "beforeBuildCommand": "cd frontend && bun run build"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
